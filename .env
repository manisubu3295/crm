# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Multi-tenancy ───────────────────────────────────────────────────────────
TENANT_REGISTRY_PATH=./server/multitenant/tenants.local.json
TENANT_ADMIN_KEY=dev-admin-key-change-in-production
DEMO_TENANT_ID=marcellotech
DEMO_TENANT_FALLBACK=false
TENANT_DB_POOL_MAX=10
TENANT_DB_IDLE_MS=30000
TENANT_DB_CONN_MS=5000

# ─── Security ────────────────────────────────────────────────────────────────
# IMPORTANT: Change this to a random 64-char string in production!
JWT_SECRET=marcellotech-crm-dev-jwt-secret-min-32-chars-change-in-prod-2026
CORS_ORIGINS=http://localhost:5173,http://localhost:5174
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

