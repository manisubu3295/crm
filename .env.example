# ─── Runtime ────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
MULTITENANT_RUNTIME=true

# ─── Multi-tenancy ──────────────────────────────────────────
TENANT_REGISTRY_PATH=./server/multitenant/tenants.local.json
TENANT_ADMIN_KEY=change-me-admin-key
DEMO_TENANT_ID=demo
DEMO_TENANT_FALLBACK=true

# Per-tenant PostgreSQL connection pool
TENANT_DB_POOL_MAX=10
TENANT_DB_IDLE_MS=30000
TENANT_DB_CONN_MS=5000

# ─── Security ───────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret-min-32-chars-long
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# ─── Redis (BullMQ + Cache) ──────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Meta / WhatsApp (Cloud API) ────────────────────────────
META_APP_SECRET=your-meta-app-secret
META_VERIFY_TOKEN=your-custom-webhook-verify-token
META_ACCESS_TOKEN=your-page-access-token
META_PHONE_NUMBER_ID=your-wa-phone-number-id
META_API_VERSION=v19.0

# ─── SendGrid (Email) ────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@yourinstitution.com
EMAIL_FROM_NAME=Your Institution CRM

# ─── Msg91 (SMS) ─────────────────────────────────────────────
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=TRACRM
MSG91_ROUTE=4                          # 4 = transactional
MSG91_OTP_TEMPLATE_ID=your-otp-template-id

# ─── Exotel (IVR) ────────────────────────────────────────────
EXOTEL_API_KEY=your-exotel-api-key
EXOTEL_API_TOKEN=your-exotel-api-token
EXOTEL_SID=your-exotel-sid
EXOTEL_CALLER_ID=your-virtual-number
EXOTEL_SUBDOMAIN=api.exotel.com

# ─── Reports ─────────────────────────────────────────────────
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
REPORT_TMP_DIR=/var/tmp/crm-reports
REPORT_PDF_CONCURRENCY=2
TEMPLATE_CACHE_TTL_MS=600000

# ─── Migrations ──────────────────────────────────────────────
MIGRATION_TRANSACTION_ENABLED=true

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=info
